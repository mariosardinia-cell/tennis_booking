# ── Sicurezza ──────────────────────────────────────────────
# Cambia con una stringa casuale lunga
SECRET_KEY=cambia-questa-chiave-segreta

# Password per entrare nel pannello admin
ADMIN_PASSWORD=tennis2026

# ── Email (opzionale) ───────────────────────────────────────
# Con Gmail: attiva "Password per le app" nelle impostazioni Google
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tuo@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
ADMIN_EMAIL=tuo@gmail.com

# ── Push notifications (opzionale) ─────────────────────────
# Genera le chiavi eseguendo: python generate_vapid.py
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:tuo@gmail.com

# ── Orari e config ──────────────────────────────────────────
OPEN_HOUR=8
CLOSE_HOUR=22

# URL pubblico dell'app (usato nelle email)
APP_URL=https://tuo-sito.railway.app

# ── Database ────────────────────────────────────────────────
